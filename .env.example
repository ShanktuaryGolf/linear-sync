# =============================================================================
# Pipeline Kit — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# Discord Bot
# ---------------------------------------------------------------------------
# Create a bot at https://discord.com/developers/applications
# Required permissions: Send Messages, Embed Links, Create Public Threads,
#   Send Messages in Threads, Use Application Commands
DISCORD_BOT_TOKEN=

# Your Discord user ID (right-click yourself → Copy User ID)
# The bot will ping you on new reports
ADMIN_USER_ID=

# Discord forum channel ID for issue tracking posts
# Create a forum channel, right-click → Copy Channel ID
FORUM_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Linear
# ---------------------------------------------------------------------------
# Create at Linear → Settings → API → Personal API Keys
LINEAR_API_KEY=

# Your Linear team ID (UUID)
# Find via: curl -s https://api.linear.app/graphql -H "Authorization: $LINEAR_API_KEY" \
#   -H "Content-Type: application/json" \
#   -d '{"query": "{ teams { nodes { id name } } }"}' | python3 -m json.tool
LINEAR_TEAM_ID=

# Your Linear project ID (UUID) — the project to track issues in
# Find via: curl -s https://api.linear.app/graphql -H "Authorization: $LINEAR_API_KEY" \
#   -H "Content-Type: application/json" \
#   -d '{"query": "{ projects { nodes { id name slugId } } }"}' | python3 -m json.tool
LINEAR_PROJECT_ID=

# Your Linear project slug (for querying)
LINEAR_PROJECT_SLUG=

# ---------------------------------------------------------------------------
# Linear Workflow State IDs
# ---------------------------------------------------------------------------
# You MUST create these custom states in Linear (Settings → Teams → Workflow)
# Then look up their IDs with:
#   curl -s https://api.linear.app/graphql -H "Authorization: $LINEAR_API_KEY" \
#     -H "Content-Type: application/json" \
#     -d '{"query": "{ workflowStates(filter: { team: { id: { eq: \"YOUR_TEAM_ID\" } } }) { nodes { id name type } } }"}' \
#     | python3 -m json.tool
#
# Required states (create these as "started" type):
#   - Human Review
#   - Gate Approved
#   - Code Review
#   - Rework
# Default states (already exist):
#   - Todo, In Progress, Done, Canceled
LINEAR_STATE_TODO=
LINEAR_STATE_IN_PROGRESS=
LINEAR_STATE_HUMAN_REVIEW=
LINEAR_STATE_GATE_APPROVED=
LINEAR_STATE_CODE_REVIEW=
LINEAR_STATE_REWORK=
LINEAR_STATE_DONE=
LINEAR_STATE_CANCELED=

# ---------------------------------------------------------------------------
# Webhook Server (for Linear → Discord status updates)
# ---------------------------------------------------------------------------
WEBHOOK_PORT=8080

# SSL certificate paths (leave empty to disable HTTPS)
# Get certs with: sudo certbot certonly --standalone -d bot.yourdomain.com
SSL_CERT=
SSL_KEY=

# ---------------------------------------------------------------------------
# Gas Town (if using multi-agent pipeline)
# ---------------------------------------------------------------------------
# Path to your Gas Town workspace root
GT_ROOT=

# Rig name for your project
GT_RIG=
